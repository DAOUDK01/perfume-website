# JWT Configuration
# IMPORTANT: Generate a strong random secret for production
# You can generate one using: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-replace-this-in-production

# Database Configuration
# MongoDB Atlas connection (primary)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/perfume-db?retryWrites=true&w=majority
MONGODB_URI_ATLAS=mongodb+srv://username:password@cluster.mongodb.net/perfume-db?retryWrites=true&w=majority

# Local MongoDB connection (optional - for development)
MONGODB_URI_LOCAL=mongodb://localhost:27017/perfume-db

# Alternative MongoDB URI name (for compatibility)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/perfume-db?retryWrites=true&w=majority

# Next.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Other Environment Variables
NODE_ENV=development

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Timeout Settings (Note: These are now handled programmatically)
# - Local DB operations: 4-5 second timeouts
# - Atlas DB operations: 6-8 second timeouts  
# - Client-side requests: 8-10 second timeouts with retry logic